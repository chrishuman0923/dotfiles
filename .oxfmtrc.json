{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": ["pnpm-lock.yaml"],
  "printWidth": 135,
  "quoteProps": "as-needed",
  "semi": true,
  "singleQuote": true,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
